{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# SMART 1 - Data Collection\n",
    "\n",
    "**Goal:** Load and explore the Kaggle house prices dataset.\n",
    "\n",
    "**Dataset:** [House Prices - Advanced Regression Techniques](https://www.kaggle.com/c/house-prices-advanced-regression-techniques)\n",
    "\n",
    "**Steps:**\n",
    "1. Download `train.csv` from Kaggle and place it in `data/raw/`\n",
    "2. Load the data with pandas\n",
    "3. Explore structure, types, and basic statistics\n",
    "4. Analyze the target variable (SalePrice)\n",
    "5. Check missing values\n",
    "6. Quick correlation analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import os\n",
    "\n",
    "sns.set_style('whitegrid')\n",
    "plt.rcParams['figure.figsize'] = (10, 6)\n",
    "plt.rcParams['font.size'] = 12"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load the Dataset\n",
    "\n",
    "Download `train.csv` from Kaggle and place it in `data/raw/` before running this notebook."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "DATA_PATH = '../data/raw/train.csv'\n",
    "\n",
    "if not os.path.exists(DATA_PATH):\n",
    "    print(f'ERROR: {DATA_PATH} not found.')\n",
    "    print('Download train.csv from Kaggle and place it in data/raw/')\n",
    "else:\n",
    "    df = pd.read_csv(DATA_PATH)\n",
    "    print(f'Dataset loaded successfully: {df.shape[0]} rows, {df.shape[1]} columns')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. First Look at the Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df.head(10)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(f'Shape: {df.shape}')\n",
    "print(f'\\nColumn types:')\n",
    "print(df.dtypes.value_counts())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df.info()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Target Variable Analysis (SalePrice)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "axes[0].hist(df['SalePrice'], bins=50, edgecolor='black', alpha=0.7)\n",
    "axes[0].set_title('SalePrice Distribution')\n",
    "axes[0].set_xlabel('Price ($)')\n",
    "axes[0].set_ylabel('Frequency')\n",
    "\n",
    "axes[1].hist(np.log1p(df['SalePrice']), bins=50, edgecolor='black', alpha=0.7, color='orange')\n",
    "axes[1].set_title('SalePrice Distribution (Log Transformed)')\n",
    "axes[1].set_xlabel('Log(Price)')\n",
    "axes[1].set_ylabel('Frequency')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(f'\\nSalePrice Statistics:')\n",
    "print(f'  Mean:   ${df[\"SalePrice\"].mean():,.0f}')\n",
    "print(f'  Median: ${df[\"SalePrice\"].median():,.0f}')\n",
    "print(f'  Std:    ${df[\"SalePrice\"].std():,.0f}')\n",
    "print(f'  Min:    ${df[\"SalePrice\"].min():,.0f}')\n",
    "print(f'  Max:    ${df[\"SalePrice\"].max():,.0f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Missing Values Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "missing = df.isnull().sum()\n",
    "missing_pct = (missing / len(df)) * 100\n",
    "missing_df = pd.DataFrame({'Count': missing, 'Percentage': missing_pct})\n",
    "missing_df = missing_df[missing_df['Count'] > 0].sort_values('Percentage', ascending=False)\n",
    "\n",
    "print(f'Columns with missing values: {len(missing_df)} / {df.shape[1]}')\n",
    "print(f'\\nTop 15 columns with most missing values:')\n",
    "missing_df.head(15)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if len(missing_df) > 0:\n",
    "    fig, ax = plt.subplots(figsize=(12, 6))\n",
    "    missing_df.head(20)['Percentage'].plot(kind='barh', ax=ax, edgecolor='black')\n",
    "    ax.set_title('Top 20 Columns with Missing Values (%)')\n",
    "    ax.set_xlabel('Percentage Missing')\n",
    "    ax.invert_yaxis()\n",
    "    plt.tight_layout()\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Numerical Features Overview"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()\n",
    "print(f'Numerical columns: {len(numeric_cols)}')\n",
    "df[numeric_cols].describe()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Categorical Features Overview"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "cat_cols = df.select_dtypes(include=['object']).columns.tolist()\n",
    "print(f'Categorical columns: {len(cat_cols)}')\n",
    "print(f'\\nCategories per column:')\n",
    "for col in cat_cols:\n",
    "    print(f'  {col}: {df[col].nunique()} unique values')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Correlation with SalePrice"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "corr_with_price = df[numeric_cols].corr()['SalePrice'].sort_values(ascending=False)\n",
    "\n",
    "print('Top 15 features correlated with SalePrice:')\n",
    "print(corr_with_price.head(16))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "top_features = corr_with_price.head(11).index.tolist()\n",
    "top_features = [f for f in top_features if f != 'SalePrice']\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 8))\n",
    "sns.heatmap(df[top_features + ['SalePrice']].corr(),\n",
    "            annot=True, fmt='.2f', cmap='coolwarm', center=0, ax=ax)\n",
    "ax.set_title('Correlation Heatmap - Top Features vs SalePrice')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Scatter Plots - Key Features vs SalePrice"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "scatter_features = ['GrLivArea', 'TotalBsmtSF', 'GarageArea', 'YearBuilt', 'OverallQual']\n",
    "scatter_features = [f for f in scatter_features if f in df.columns]\n",
    "\n",
    "fig, axes = plt.subplots(1, len(scatter_features), figsize=(5 * len(scatter_features), 5))\n",
    "if len(scatter_features) == 1:\n",
    "    axes = [axes]\n",
    "\n",
    "for ax, feature in zip(axes, scatter_features):\n",
    "    ax.scatter(df[feature], df['SalePrice'], alpha=0.3, edgecolors='none')\n",
    "    ax.set_xlabel(feature)\n",
    "    ax.set_ylabel('SalePrice')\n",
    "    ax.set_title(f'{feature} vs SalePrice')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Save Summary"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "summary_lines = [\n",
    "    '=== DATASET SUMMARY ===',\n",
    "    f'File: train.csv',\n",
    "    f'Shape: {df.shape[0]} rows x {df.shape[1]} columns',\n",
    "    f'\\n--- Column Types ---',\n",
    f'  Numerical: {len(numeric_cols)}',\n",
    f'  Categorical: {len(cat_cols)}',\n",
    "    f'\\n--- Missing Values ---',\n",
    f'  Columns with missing data: {len(missing_df)}',\n",
    "    f'\\n--- SalePrice ---',\n",
    f'  Mean: ${df[\"SalePrice\"].mean():,.0f}',\n",
    f'  Median: ${df[\"SalePrice\"].median():,.0f}',\n",
    f'  Std: ${df[\"SalePrice\"].std():,.0f}',\n",
    "    f'\\n--- Top Correlations with SalePrice ---',\n",
    "]\n",
    "\n",
    "for feat, val in corr_with_price.head(6).items():\n",
    "    summary_lines.append(f'  {feat}: {val:.4f}')\n",
    "\n",
    "summary_text = '\\n'.join(summary_lines)\n",
    "print(summary_text)\n",
    "\n",
    "os.makedirs('../data/raw', exist_ok=True)\n",
    "with open('../data/raw/dataset_summary.txt', 'w') as f:\n",
    "    f.write(summary_text)\n",
    "\n",
    "print(f'\\nSummary saved to data/raw/dataset_summary.txt')"
   ]
  }
 ],
